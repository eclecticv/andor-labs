---
import Button from "../ds/Button.astro";
import Input from "../ds/Input.astro";
// The on-brand form posts to /api/subscribe (a Cloudflare Pages Function added at
// deploy) which forwards to the Beehiiv API. Keeps the form pixel-matched to the
// brand instead of Beehiiv's un-styleable cross-origin iframe.
---
<section class="aol-newsletter" style="background:var(--paper)">
  <div style="max-width:var(--content-width);margin:0 auto;padding:var(--section-pad-y) var(--gutter)">
    <div style="position:relative;border:1.5px solid var(--ink-900);border-radius:var(--radius-md);box-shadow:var(--shadow-hard);background:var(--surface-card);padding:var(--space-10) var(--space-10) var(--space-8)">
      <span style="position:absolute;top:0;left:24px;transform:translateY(-50%);background:var(--paper-pure);padding:0 10px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--blue-600)">Newsletter</span>
      <h2 style="font-family:var(--font-display);font-weight:400;font-size:27px;line-height:1.22;letter-spacing:0;margin:0 0 var(--space-3);max-width:24ch">Tactical growth tips for adtech founders &amp; operators.</h2>
      <p style="font-size:16px;line-height:1.5;color:var(--ink-600);margin:0 0 var(--space-6);max-width:46ch">Keep up with the latest developments in AI, GTM, and adtech. 1x post / week. Unsubscribe anytime.</p>
      <form data-subscribe style="display:flex;gap:var(--space-3);flex-wrap:wrap;align-items:center">
        <Input
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder="you@company.com"
          aria-label="Email address"
          style="flex:1 1 240px"
        />
        <Button type="submit" variant="primary" size="lg" arrow>Subscribe</Button>
      </form>
      <p class="aol-news-msg" hidden aria-live="polite" style="font-family:var(--font-mono);font-size:12px;letter-spacing:0.02em;margin:14px 0 0;color:var(--blue-600)"></p>
    </div>
  </div>
</section>

<script>
  const form = document.querySelector<HTMLFormElement>("[data-subscribe]");
  const msg = document.querySelector<HTMLElement>(".aol-news-msg");
  const show = (t: string, ok = true) => {
    if (!msg) return;
    msg.textContent = t;
    msg.style.color = ok ? "var(--blue-600)" : "var(--red-600)";
    msg.hidden = false;
  };
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = new FormData(form).get("email");
    try {
      const res = await fetch("/api/subscribe", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ email }),
      });
      if (res.ok) { form.reset(); show("Subscribed — check your inbox to confirm."); }
      else show("Hmm, that didn't go through. Try again?", false);
    } catch {
      show("Hmm, that didn't go through. Try again?", false);
    }
  });
</script>
