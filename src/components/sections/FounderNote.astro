---
import Photo from "../ds/Photo.astro";
import StatusMark from "../ds/StatusMark.astro";

const label = "a note from the founder";
const sames = ["“Optimize your ad revenue…”", "“Maximize your ad revenue…”", "“Supercharge your ad revenue…”"];
const beforeItems = ["Blends into the category", "Buyers can't tell you apart", "Leaky funnel, long sales cycles"];
const afterItems = ["A distinct, defensible position", "Buyers instantly get why you", "A tight funnel, end to end"];
const beforeRow = "display:flex;gap:9px;align-items:flex-start;font-family:var(--font-mono);font-size:12.5px;line-height:1.4;color:var(--ink-500)";
const afterRow = "display:flex;gap:9px;align-items:flex-start;font-family:var(--font-mono);font-size:12.5px;line-height:1.4;color:var(--ink-800)";
---
<section id="founder" style="border-bottom:1px solid var(--ink-200);background:var(--paper)">
  <div style="max-width:var(--content-width);margin:0 auto;padding:var(--space-16) var(--gutter)">
    <div class="aol-grid" style="position:relative;border:1.5px solid var(--ink-900);border-radius:var(--radius-md);box-shadow:var(--shadow-hard);background:var(--surface-card);padding:34px 36px 30px">
      <span style="position:absolute;top:0;left:24px;transform:translateY(-50%);background:var(--paper);padding:0 10px;font-family:var(--font-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--blue-600)">{label}</span>
      <h2 style="font-family:var(--font-display);font-weight:400;font-size:33px;line-height:1.24;letter-spacing:-0.01em;margin:6px 0 20px;color:var(--ink-900)">Most adtech startups look the same, sound the same, go to the same events.</h2>
      <div style="display:flex;align-items:center;gap:12px;margin:0 0 22px">
        <Photo src="/founder.png" alt="Vishveshwar Jatain" width={50} height={50} pixel={0.35} shape="circle" contrast={1.16} style="flex:none" />
        <div>
          <div style="font-family:var(--font-serif);font-size:16px;font-weight:600;color:var(--ink-900)">Vishveshwar Jatain</div>
          <div style="font-family:var(--font-mono);font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--blue-600);margin-top:2px">Founder, And/or Labs</div>
        </div>
      </div>
      <p style="font-family:var(--font-serif);font-size:17px;line-height:1.62;color:var(--ink-800);margin:0 0 22px;max-width:var(--measure)">
        {sames.map((q, i) => <>{q}{i < 2 && <br />}</>)}<br /><br />Sounds familiar?
      </p>
      <div style="font-family:var(--font-serif);font-size:17px;line-height:1.62;color:var(--ink-800);max-width:var(--measure)">
        <p style="margin:0 0 14px">By positioning your startup the same way as everybody else in your category, you're failing to give buyers any compelling reason to choose you.</p>
        <p style="margin:0 0 14px">When buyers are on the fence about you, it leads to fewer conversions, longer sales cycles, and higher churn rates. Every step of your revenue process is leaky.</p>
        <p style="margin:0;color:var(--ink-900)">After leading marketing, content strategy, and sales ops for startups that sold for &gt;$100M, I now help adtech teams make their solution the obvious category pick.</p>
      </div>
      <div style="margin-top:26px;border-top:1px solid var(--ink-200)"></div>

      <div style="margin-top:24px;background:var(--paper-pure);border:1px solid var(--ink-200);border-radius:var(--radius-md);padding:24px 26px;display:grid;grid-template-columns:1fr 1fr;gap:30px">
        <div>
          <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink-500);margin-bottom:13px">Before</div>
          <div style="display:grid;gap:10px">
            {beforeItems.map((s) => (
              <div style={beforeRow}>
                <span style="flex:none;position:relative;top:1px"><StatusMark kind="no" size={16} /></span>{s}
              </div>
            ))}
          </div>
        </div>
        <div>
          <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:0.1em;text-transform:uppercase;color:var(--blue-600);margin-bottom:13px">After</div>
          <div style="display:grid;gap:10px">
            {afterItems.map((s) => (
              <div style={afterRow}>
                <span style="flex:none;position:relative;top:1px"><StatusMark kind="yes" size={16} /></span>{s}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
