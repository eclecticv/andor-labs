---
import Button from "../ds/Button.astro";
import Badge from "../ds/Badge.astro";

const PRESS = ["Digiday", "Forbes", "Adweek", "ExchangeWire", "eMarketer"];

// ANDOR/OS boot log — server-rendered in its FINAL state (no-JS and
// reduced-motion visitors see the completed syscheck); JS replays it as a
// slow boot on load. Dotted leaders align every status to one column.
const lead = (name: string) => "  " + name + " " + ".".repeat(20 - name.length) + " ";
const BOOT_LINES: { text: string; status?: string; prompt?: boolean }[] = [
  { text: "SYSCHECK" },
  { text: lead("design"), status: "OK" },
  { text: lead("positioning"), status: "OK" },
  { text: lead("distribution"), status: "OK" },
  { text: lead("conversion funnel"), status: "OK" },
  { text: lead("tech stack"), status: "RUNNING" },
  { text: " " },
  { text: "all systems operational" },
  { text: "> ", prompt: true },
];
---
<section class="aol-hero" style="border-bottom:1px solid var(--ink-200);background:var(--paper)">
  <div class="aol-hero-inner" style="max-width:var(--container-width);width:100%;margin:0 auto">
    <div class="aol-eyebrow aol-hero__eyebrow" data-r style="--r:0">Est. 2025</div>
    <p class="aol-hero__founder" data-r style="font-family:var(--font-mono);font-size:13px;line-height:1.5;letter-spacing:0.02em;color:var(--ink-600);--r:0">Founded by former Head of Marketing at<br /><strong style="font-weight:400;color:var(--ink-900)">Blockthrough</strong> &amp; <strong style="font-weight:400;color:var(--ink-900)">AdPushup</strong> <Badge variant="tint" class="aol-founderpill">Sold for &gt;$100M</Badge></p>
    <h1 class="aol-hero__headline" data-r style="font-family:var(--font-display);font-weight:400;font-size:42px;line-height:1.18;letter-spacing:0;max-width:30.5rem;--r:1">Full-stack growth partner for adtech startups</h1>
    <div class="aol-hero__term" data-r style="--r:4">
      <div class="aol-term">
        <div class="aol-term__head" aria-hidden="true">
          <span>ANDOR/OS v1.0</span>
          <span class="aol-term__head-right">CRT-01 <span class="aol-term__led"></span></span>
        </div>
        <div class="aol-term__screen">
          <div class="aol-term__log" aria-hidden="true">
            {BOOT_LINES.map((l) => (
              <div class={"aol-term__line" + (l.prompt ? " aol-term__prompt" : "")}>{l.text}{l.status && <span class={"aol-term__ok" + (l.status === "RUNNING" ? " aol-term__ok--live" : "")}>{l.status}</span>}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
    <p class="aol-hero__subhead" data-r style="font-size:21px;line-height:1.5;color:var(--ink-600);max-width:42ch;--r:2">
      We help early-stage adtech startups win their category through clear positioning, content engineering, and market intel your competitors don't have.
    </p>
    <div class="aol-hero__cta" data-r style="--r:3"><Button size="lg" variant="primary" arrow href="https://calendar.app.google/X1YiTW5qcfR3WQ6LA" target="_blank" rel="noopener">Book a call</Button></div>
  </div>
  <div class="aol-grid-blue" data-r style="border-top:1px solid var(--ink-200);--r:5">
    <div style="max-width:var(--container-width);width:100%;margin:0 auto;padding:var(--space-6) var(--gutter)">
    <div class="aol-credstrip" style="border-top:0;padding-top:0">
      <div class="aol-credstrip__cell">
        <span class="aol-eyebrow">As seen on</span>
        <span class="aol-credstrip__val">{PRESS.join("  ·  ")}</span>
      </div>
      <div class="aol-credstrip__cell">
        <span class="aol-eyebrow">Brand partners</span>
        <span class="aol-credstrip__val">AirOps  ·  Superdesign  ·  Snitcher</span>
      </div>
    </div>
    </div>
  </div>
</section>

<script>
  // ── ANDOR/OS boot — the log is server-rendered in its final state; with JS +
  // motion allowed we hide it and replay a slow, deliberate boot (line lands,
  // beat, status lands). Final state = the completed syscheck resting on a prompt.
  // Never blocks page load — it's the hero figure's own behavior, not a gate.
  const term = document.querySelector<HTMLElement>(".aol-term");
  const lines = term ? Array.from(term.querySelectorAll<HTMLElement>(".aol-term__line")) : [];
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;

  let timers: number[] = [];
  const clearTimers = () => { timers.forEach(clearTimeout); timers = []; };

  const runBoot = () => {
    if (!term) return;
    clearTimers();
    term.classList.remove("is-booted");
    term.classList.add("is-on", "is-booting");
    lines.forEach((l) => {
      l.classList.remove("is-in");
      l.querySelector(".aol-term__ok")?.classList.remove("is-in");
    });
    // Deliberate cadence: header, pause, then each check prints and its
    // status lands a beat later — the old-POST rhythm, unhurried.
    let t = 500;
    lines.forEach((l) => {
      const ok = l.querySelector<HTMLElement>(".aol-term__ok");
      const isBlank = l.textContent!.trim() === "";
      timers.push(window.setTimeout(() => l.classList.add("is-in"), t));
      if (ok) {
        timers.push(window.setTimeout(() => ok.classList.add("is-in"), t + 340));
        t += 780;
      } else {
        t += isBlank ? 220 : 620;
      }
    });
    timers.push(window.setTimeout(() => {
      term.classList.remove("is-booting");
      term.classList.add("is-booted");
    }, t + 300));
  };

  if (term) {
    if (reduce) {
      term.classList.add("is-on", "is-booted");
    } else {
      window.setTimeout(runBoot, 450);
    }
  }
</script>
