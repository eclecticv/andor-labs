---
import Card from "../ds/Card.astro";
import Badge from "../ds/Badge.astro";
import Button from "../ds/Button.astro";
import Divider from "../ds/Divider.astro";
import Link from "../ds/Link.astro";

const plans = [
  {
    kind: "Audit", name: "GTM Audit",
    blurb: "A focused teardown of your site, positioning, and funnel — with a prioritized list of what to fix first.",
    price: "$995", per: "one-time", cta: "Book your audit",
    feats: ["Positioning & messaging review", "Site & funnel teardown", "Prioritized fix list"],
    raised: false, flag: null as string | null,
  },
  {
    kind: "Sprint", name: "Makeover Sprint",
    blurb: "Put your best foot forward with buyers by showing up with a fresh identity and compelling pitch.",
    price: "$9,995", per: "one-time", cta: "Reserve your sprint",
    feats: ["Brand identity refresh", "Positioning workshop", "New, AI-ready site"],
    raised: false, flag: null as string | null,
  },
  {
    kind: "Retainer", name: "Fractional CMO",
    blurb: "Done-for-you marketing to help adtech founders & GTM leaders build awareness and pipeline.",
    price: "$6,995", per: "/mo · 3-month min", cta: "Book intro call",
    feats: ["Monthly strategy call", "Blog & social content", "Growth reporting"],
    raised: true, flag: "Most teams start here",
  },
];
---
<section id="how-we-work" style="border-bottom:1px solid var(--ink-200);background:var(--surface-card)">
  <div style="max-width:1000px;margin:0 auto;padding:84px 28px">
    <div class="aol-eyebrow" style="margin-bottom:14px">how we work</div>
    <h2 class="aol-display-mono" style="font-size:clamp(30px, 5vw, 40px);margin:0 0 36px">Three ways to start.</h2>
    <div class="aol-grid-3" style="display:grid;gap:20px;align-items:start">
      {plans.map((p) => (
        <Card variant={p.raised ? "raised" : "flat"} padding="lg" style="display:flex;flex-direction:column;position:relative;background:var(--paper-pure)">
          {p.flag && (
            <div style="position:absolute;top:0;right:18px;transform:translateY(-50%);background:var(--blue-600);color:#fff;font-family:var(--font-mono);font-size:10px;letter-spacing:0.08em;text-transform:uppercase;padding:4px 10px;border-radius:var(--radius-sm)">{p.flag}</div>
          )}
          <Badge variant={p.raised ? "blue" : "outline"} dot>{p.kind}</Badge>
          <h3 style="font-size:26px;margin:14px 0 8px">{p.name}</h3>
          <p style="font-size:16px;color:var(--ink-600);line-height:1.5;margin:0 0 18px">{p.blurb}</p>
          <div style="display:grid;gap:9px;margin-bottom:22px">
            {p.feats.map((f) => (
              <div style="display:flex;gap:9px;align-items:baseline;font-family:var(--font-mono);font-size:13px;color:var(--ink-700)">
                <span style="color:var(--blue-600)">+</span>{f}
              </div>
            ))}
          </div>
          <div style="margin-top:auto">
            <Button variant={p.raised ? "primary" : "secondary"} fullWidth data-open-contact>{p.cta}</Button>
            <div style="margin:18px 0 0"><Divider /></div>
            <div style="display:flex;align-items:baseline;justify-content:center;gap:8px;margin-top:16px">
              <span style="font-family:var(--font-serif);font-size:32px;font-weight:600;color:var(--ink-900)">{p.price}</span>
              <span style="font-family:var(--font-mono);font-size:12px;color:var(--ink-500)">{p.per}</span>
            </div>
          </div>
        </Card>
      ))}
    </div>
    <p style="font-family:var(--font-mono);font-size:13px;color:var(--ink-500);text-align:center;margin-top:28px">
      Have a custom project? <Link arrow data-open-contact>Let's talk</Link>
    </p>
  </div>
</section>
