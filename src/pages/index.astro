---
import Base from "../layouts/Base.astro";
import SiteHeader from "../components/sections/SiteHeader.astro";
import Hero from "../components/sections/Hero.astro";
import FounderNote from "../components/sections/FounderNote.astro";
import Compare from "../components/sections/Compare.astro";
import Offers from "../components/sections/Offers.astro";
import FAQ from "../components/sections/FAQ.astro";
// Newsletter hidden until the Beehiiv email capture is wired (Newsletter.astro is ready).
// import Newsletter from "../components/sections/Newsletter.astro";
import SiteFooter from "../components/sections/SiteFooter.astro";
import SiteMotion from "../components/SiteMotion.astro";
import CopyDiffer from "../components/CopyDiffer.astro";
---
<Base>
  <SiteHeader />
  <main>
    <Hero />
    <FounderNote />
    <Compare />
    <Offers />
    <FAQ />
    {/* <Newsletter /> — hidden until email capture is wired */}
  </main>
  <SiteFooter />
  <SiteMotion />
  {import.meta.env.DEV && <CopyDiffer />}
</Base>
