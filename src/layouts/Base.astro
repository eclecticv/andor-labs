---
import "../styles/main.css";
import AgentationDevTool from "../components/Agentation.tsx";
import CopyDiffer from "../components/CopyDiffer.astro";

interface Props {
  title?: string;
  description?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  ogImage?: string; // site-relative path; defaults to the site card
  ogImageAlt?: string;
}
const {
  title = "And/or Labs — the GTM OS for adtech startups",
  description = "We help early-stage adtech startups win their category through clear positioning, content engineering, and sales intelligence your competitors don't have.",
  ogType = "website",
  publishedTime,
  ogImage: ogImagePath = "/og.png",
  ogImageAlt = "And/or Labs — the GTM OS for adtech startups",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(ogImagePath, Astro.site).href;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <script is:inline>document.documentElement.classList.add("js");</script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#ffffff" />
    <meta property="og:site_name" content="And/or Labs" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@eclecticV" />
    <meta name="twitter:creator" content="@eclecticV" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;1,6..72,400&display=swap"
    />
    <link rel="preload" href="/fonts/InstrumentSerif-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/DepartureMono-Regular.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <slot />

    {/* Dev-only visual feedback — annotate the live page, agent reads it via MCP on :4747 */}
    {import.meta.env.DEV && <AgentationDevTool client:only="react" />}

    {/* Dev-only inline copy editor — edit text in place, copy a diff to hand back */}
    {import.meta.env.DEV && <CopyDiffer />}
  </body>
</html>
